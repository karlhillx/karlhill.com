# Laravel / PHP project .gitignore
# Source of truth: lynx-devops/templates/laravel.gitignore

# Dependencies
/vendor
/node_modules

# Environment
.env
.env.backup
.env.production
/auth.json

# Laravel build / runtime
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail

# PHPUnit / IDE
.phpactor.json
.phpunit.result.cache
/.phpunit.cache
/.fleet
/.idea
/.nova
/.vscode
/.zed

# Homestead
Homestead.json
Homestead.yaml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
