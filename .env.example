APP_NAME="Karl Hill"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database is optional — the site uses file cache/session and flat-file blog posts.
# DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@karlhill.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

GITHUB_TOKEN=
GITHUB_USERNAME=karlhillx

# dev.to API key for `php artisan post:syndicate`. Generate at:
#   https://dev.to/settings/extensions
DEVTO_API_KEY=

# Set GOOGLE_ANALYTICS_MEASUREMENT_ID to enable GA4 (e.g. G-XXXXXXXXXX)
GOOGLE_ANALYTICS_ENABLED=false
GOOGLE_ANALYTICS_MEASUREMENT_ID=

# Lightweight privacy-friendly analytics (https://plausible.io)
PLAUSIBLE_ENABLED=false
PLAUSIBLE_DOMAIN=karlhill.com

PRODUCTION=karlhill.com
SSH_USER=karl
